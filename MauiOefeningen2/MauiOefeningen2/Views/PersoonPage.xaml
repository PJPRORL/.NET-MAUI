<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiOefeningen2.Views.PersoonPage"
             xmlns:model = "clr-namespace:MauiOefeningen2.Models"
             xmlns:vieuwmodel = "clr-namespace:MauiOefeningen2.ViewModels"
             x:DataType="vieuwmodel:PersoonViewModel"
             Title="{Binding Title}">
    <Grid RowDefinitions="*, auto" ColumnDefinitions="*, auto"
          Margin="10">
        <CollectionView Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding Personen}" SelectedItem="{Binding Persoon}" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:Persoon">
                    <VerticalStackLayout>
                        <Label 
                            Text="Voornaam:"
                            VerticalOptions="Center" 
                            HorizontalOptions="Center" />
                        <Entry
                            Text="{Binding Voornaam}"
                            />
                        <Label
                            Text="Geboortedatum:"
                            VerticalOptions="Center"
                            HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>